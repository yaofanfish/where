def case_insens(fn):
	def insens_fn(*v, **k):
		nv = [i.lower() if isinstance(i, str) else i for i in v]
		nk = {_: i.lower() if isinstance(i, str) else i for _, i in k}
		re = fn(*nv, **nk)
		return re
	return insens_fn

